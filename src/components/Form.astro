<section class="contact">
    <header class="contact-header">
        <h2 class="contact-title">CONTACT</h2>
    </header>

    <form class="contact-form">
        <div class="contact-row">
            <input class="contact-input" type="text" placeholder="name" />
            <input class="contact-input" type="email" placeholder="e-mail" />
        </div>

        <input class="contact-input contact-input--message" type="text" placeholder="message" />

        <button class="contact-submit" type="submit">submit</button>
    </form>
</section>
