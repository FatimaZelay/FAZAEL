<script>
    import { fade } from "astro:transitions";

    const menuButton = document.querySelector(".open-menu") as HTMLElement;
    const nav = document.querySelector("nav") as HTMLElement;
    const closeMenuButton = document.querySelector(
        ".close-menu",
    ) as HTMLElement;

    menuButton.addEventListener("click", openMenu); //https://docs.astro.build/en/reference/astro-syntax/#dynamic-attributes
    closeMenuButton.addEventListener("click", closeMenu);

    function openMenu() {
        nav.classList.add("open");
    }

    function closeMenu() {
        nav.classList.remove("open");
    }
</script>

